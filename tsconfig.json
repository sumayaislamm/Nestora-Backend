{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force"
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}